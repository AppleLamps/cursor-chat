# No server-side API keys are required for AskCursor.

# BYOK flow:
# - Users paste a Cursor API key in the browser UI.
# - The app forwards that key to /api/repos and /api/chat per request.
# - Keys are never persisted on the server.
# - Optional "remember on this device" stores the key in browser localStorage only.

# Optional local overrides (usually not needed):
# NODE_ENV=development

# Implement mode guardrails:
# - Set to "false" to disable all write-capable Cursor agent runs.
# ASKCURSOR_ENABLE_IMPLEMENT_MODE=true
#
# - Set a stable secret in production so agent resume tokens survive deploys.
#   If omitted, the app uses a per-process random secret and old agent sessions
#   will require starting a new chat after restart.
# ASKCURSOR_AGENT_SESSION_SECRET=
#
# - Optional comma-separated allowlists. Values support "*" wildcards.
#   Repos can be full URLs or "owner/repo" slugs.
# ASKCURSOR_IMPLEMENT_ALLOWED_OWNERS=
# ASKCURSOR_IMPLEMENT_ALLOWED_REPOS=
# ASKCURSOR_IMPLEMENT_ALLOWED_BRANCHES=
#
# - Protected branches are blocked for Implement mode by default:
#   main, master, prod, production, release, release/*, hotfix/*
# ASKCURSOR_IMPLEMENT_PROTECTED_BRANCHES=
# ASKCURSOR_ALLOW_PROTECTED_IMPLEMENT_BRANCHES=false
